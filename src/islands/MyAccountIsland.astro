---
// Renders client-side only — shows linked identities and preferences
---
<div id="my-account-root">
  <p class="text-muted">Loading…</p>
</div>

<script>
import { getAuth0Client, apiFetch, type MeResponse } from '../utils/auth';

const root = document.getElementById('my-account-root') as HTMLElement;

const CONNECTION_LABEL: Record<string, string> = {
  email: 'Email / Password',
  'google-oauth2': 'Google',
  github: 'GitHub',
  facebook: 'Facebook',
};

async function render() {
  const auth0 = await getAuth0Client();

  if (!(await auth0.isAuthenticated())) {
    root.innerHTML = `
      <div class="text-center" style="padding: 60px 0">
        <p class="lead">You need to be logged in to view your account.</p>
        <button id="acc-login-btn" class="btn btn-primary btn-lg">Log in</button>
      </div>`;
    (document.getElementById('acc-login-btn') as HTMLElement).addEventListener('click', () =>
      auth0.loginWithRedirect()
    );
    return;
  }

  const res = await apiFetch('/me');
  const me: MeResponse = await res.json();

  const identityRows = me.identities.map(id => `
    <tr>
      <td>${id.email ?? '—'}</td>
      <td>${CONNECTION_LABEL[id.connection] ?? id.connection}</td>
      <td>${id.provider}</td>
      <td><small class="text-muted">${id.linked_at.slice(0, 10)}</small></td>
    </tr>
  `).join('');

  root.innerHTML = `
    <div class="row">
      <div class="col-md-8">

        <h3>Linked accounts</h3>
        <table class="table table-bordered">
          <thead>
            <tr>
              <th>Email</th>
              <th>Method</th>
              <th>Provider</th>
              <th>Linked</th>
            </tr>
          </thead>
          <tbody>${identityRows}</tbody>
        </table>
        <button id="link-account-btn" class="btn btn-default">
          <span class="glyphicon glyphicon-plus"></span> Link another account
        </button>
        <span id="link-status" class="text-muted" style="margin-left: 12px"></span>

        <h3 style="margin-top: 32px">Contact email</h3>
        <p class="text-muted">Used for order confirmations and newsletters.</p>
        <div class="form-group">
          <input id="primary-email-input" type="email" class="form-control"
            value="${me.primary_email ?? ''}"
            placeholder="your@email.com"
            style="max-width: 360px"
          >
        </div>
        <button id="save-email-btn" class="btn btn-primary">Save</button>
        <span id="save-email-status" class="text-muted" style="margin-left: 12px"></span>

        <p class="text-muted" style="margin-top: 40px; font-size: 0.8em">
          User ID: <code>${me.user_id}</code>
        </p>

      </div>
    </div>`;

  // Link another account
  (document.getElementById('link-account-btn') as HTMLElement).addEventListener('click', async () => {
    const status = document.getElementById('link-status') as HTMLElement;
    status.textContent = 'Opening login…';
    try {
      await auth0.loginWithPopup({
        authorizationParams: {
          audience: (document.getElementById('my-account-root') as HTMLElement).dataset.audience,
        }
      });
      const linkToken = await auth0.getTokenSilently({
        authorizationParams: {
          audience: (document.getElementById('my-account-root') as HTMLElement).dataset.audience,
        },
        cacheMode: 'off',
      });
      status.textContent = 'Linking…';
      const res = await apiFetch('/me/link', {
        method: 'POST',
        body: JSON.stringify({ link_token: linkToken }),
      });
      if (res.ok) {
        status.textContent = 'Linked! Refreshing…';
        await render(); // re-render with updated identities
      } else {
        const err = await res.json();
        status.textContent = `Failed: ${err.error}`;
      }
    } catch (err: any) {
      status.textContent = err.message.includes('cancelled') ? 'Cancelled.' : `Error: ${err.message}`;
    }
  });

  // Save contact email
  (document.getElementById('save-email-btn') as HTMLElement).addEventListener('click', async () => {
    const input = document.getElementById('primary-email-input') as HTMLInputElement;
    const status = document.getElementById('save-email-status') as HTMLElement;
    status.textContent = 'Saving…';
    const res = await apiFetch('/me', {
      method: 'PATCH',
      body: JSON.stringify({ primary_email: input.value }),
    });
    status.textContent = res.ok ? 'Saved ✓' : 'Failed to save.';
  });
}

render().catch(err => {
  root.innerHTML = `<p class="text-danger">Failed to load account: ${err.message}</p>`;
});
</script>
